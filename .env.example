# Potraces Environment Variables

# App Configuration
APP_NAME=Potraces
APP_VERSION=1.0.0

# AI / Vision APIs
# ───────────────────────────────────────────────────────────────────────────
# The Gemini + Anthropic keys are SERVER-SIDE ONLY — never EXPO_PUBLIC_ vars.
# All AI calls route through the `ai-proxy` edge function, which holds the keys
# and meters usage per identity. Set them as Supabase secrets:
#   supabase secrets set GEMINI_API_KEY=...  ANTHROPIC_API_KEY=...
# GEMINI_API_KEY=...
# ANTHROPIC_API_KEY=...

# Supabase (backend sync + order link)
EXPO_PUBLIC_SUPABASE_URL=https://iydqeeonaljqapulboaz.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google Sign-In (dev build only — not Expo Go)
# WEB client ID from Google Cloud Console -> APIs & Services -> Credentials.
# The matching iOS client ID goes in app.json under the google-signin plugin's iosUrlScheme.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id

# Payment Gateway — Tap to Pay on iPhone (Stripe Terminal), pilot
# ───────────────────────────────────────────────────────────────────────────
# Master pilot flag. Leave false until the operator prerequisites below are
# done. When false, NOTHING Stripe-related initializes (Android/web/disabled
# builds carry zero Stripe runtime code paths).
EXPO_PUBLIC_TAP_TO_PAY_ENABLED=false
# Stripe Terminal Location id (acct_/tml_… -> a Location). REQUIRED by the SDK
# to connect a Tap to Pay reader. Create one in the Stripe dashboard
# (Terminal -> Locations) for the pilot's single platform account.
EXPO_PUBLIC_STRIPE_TERMINAL_LOCATION_ID=
# Set true on a dev build to use Stripe's SIMULATED reader (test mode) for the
# full charge flow without real card hardware. Keep false in production.
EXPO_PUBLIC_TAP_TO_PAY_SIMULATED=false
#
# SERVER-SIDE ONLY — never an EXPO_PUBLIC_ var. Set as a Supabase edge function
# secret (`supabase secrets set STRIPE_SECRET_KEY=sk_…`). Read solely by the
# terminal-connection-token edge function; it is never bundled into the app.
# STRIPE_SECRET_KEY=sk_live_or_test_secret_key

# DuitNow QR payment provider — Phase 2 (soundbox-replacement push)
# ───────────────────────────────────────────────────────────────────────────
# 'none' (default): static embedded-amount QR only (Phase 1) with manual
#   "received" confirmation. 'fiuu' | 'hitpay': a PSP issues the QR via API and
#   fires a webhook on payment, which pushes "Payment received" to the seller's
#   phone(s) — replacing a physical DuitNow soundbox. Only works for PSP-issued
#   QRs; a bank-app standee QR has no webhook (that's the Phase 3 honest path).
EXPO_PUBLIC_QR_PROVIDER=none
#
# SERVER-SIDE ONLY (Supabase edge secrets, never EXPO_PUBLIC_). Per-provider
# webhook signing secret, verified by the qr-payment-webhook edge function.
# Register the PSP webhook URL as:
#   https://<project>.functions.supabase.co/qr-payment-webhook?provider=<name>
# HITPAY_WEBHOOK_SALT=...
# FIUU_WEBHOOK_SECRET=...
