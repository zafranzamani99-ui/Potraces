{
  "expo": {
    "name": "Potraces",
    "slug": "potraces",
    "scheme": "potraces",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#F9F9F7"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.potraces.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#F9F9F7"
      },
      "package": "com.potraces.app",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {},
    "plugins": [
      [
        "expo-contacts",
        {
          "contactsPermission": "Potraces needs access to contacts for splitting expenses."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Potraces needs access to your photos to scan receipts.",
          "cameraPermission": "Potraces needs access to your camera to scan receipts."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-audio",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      "expo-font",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "fbef59ba-65ba-42fd-abbf-74c40f3e2366"
      }
    },
    "owner": "zafranzamani12",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/fbef59ba-65ba-42fd-abbf-74c40f3e2366"
    }
  }
}
