{
  "expo": {
    "name": "Potraces",
    "slug": "potraces",
    "scheme": "potraces",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#F9F9F7",
      "dark": {
        "backgroundColor": "#121212"
      }
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.potraces.app",
      "usesAppleSignIn": true,
      "associatedDomains": [
        "applinks:jejakbaki.my",
        "applinks:www.jejakbaki.my"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": [
              "C617.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": [
              "35F9.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": [
              "E174.1"
            ]
          }
        ]
      },
      "entitlements": {
        "com.apple.developer.proximity-reader.payment.acceptance": true,
        "aps-environment": "production"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#F9F9F7"
      },
      "package": "com.potraces.app",
      "googleServicesFile": "./google-services.json",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "jejakbaki.my"
            },
            {
              "scheme": "https",
              "host": "www.jejakbaki.my"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {},
    "plugins": [
      [
        "expo-contacts",
        {
          "contactsPermission": "Potraces needs access to contacts for splitting expenses."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Potraces needs access to your photos to scan receipts.",
          "cameraPermission": "Potraces needs the camera to scan receipts and your DuitNow QR standee."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Potraces needs the camera to scan receipts and your DuitNow QR standee."
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-audio",
        {
          "microphonePermission": "Potraces uses the microphone so you can speak your expenses instead of typing."
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      "expo-font",
      "expo-asset",
      "react-native-document-scanner-plugin",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.376098674310-3rqmhbmr0v9b9j5p9kgvkj6sqodjshl9"
        }
      ],
      [
        "@stripe/stripe-terminal-react-native",
        {
          "locationWhenInUsePermission": "Location access is required to accept card payments."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Potraces uses the microphone so you can speak entries to Echo.",
          "speechRecognitionPermission": "Potraces uses speech recognition to show your words live as you speak."
        }
      ],
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Potraces uses Face ID to unlock the app and keep your money data private."
        }
      ],
      "@sentry/react-native",
      "expo-quick-actions",
      [
        "expo-share-extension",
        {
          "activationRules": [
            {
              "type": "image",
              "max": 4
            },
            {
              "type": "file",
              "max": 4
            },
            {
              "type": "text"
            },
            {
              "type": "url",
              "max": 1
            }
          ],
          "excludedPackages": [
            "expo-dev-client",
            "expo-splash-screen"
          ]
        }
      ],
      "expo-localization",
      "expo-web-browser",
      "expo-mail-composer"
    ],
    "owner": "zafranzamani",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/48e7d14d-4320-467b-a02a-72d41a4d33d9"
    },
    "extra": {
      "eas": {
        "projectId": "48e7d14d-4320-467b-a02a-72d41a4d33d9"
      }
    }
  }
}
